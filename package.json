{
  "name": "vtex-product-feed-mcp",
  "version": "0.1.0",
  "description": "VTEX Product Feed MCP — canonical feed platform and MCP tools",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:bootstrap": "ts-node --transpile-only scripts/db-bootstrap.ts",
    "db:seed": "ts-node --transpile-only scripts/db-seed.ts",
    "simulate:event": "ts-node --transpile-only scripts/simulate-event.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "uuid": "^10.0.0",
    "crypto": "*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.12",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
